@model IEnumerable<EventDetails>
@{
    ViewData["Title"] = "Manage Events";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-calendar-alt me-2"></i>Manage Events</h2>
    <a href="/Admin/CreateEvent" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Create New Event
    </a>
</div>

<div class="row g-4">
    @foreach (var eventItem in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-info">@eventItem.EventCategory</span>
                        <span class="badge @(eventItem.Status == "Active" ? "bg-success" : "bg-secondary")">
                            @eventItem.Status
                        </span>
                    </div>
                    <h5 class="card-title">@eventItem.EventName</h5>
                    <p class="text-muted small">@eventItem.Description?.Substring(0, Math.Min(80, eventItem.Description?.Length ?? 0))...</p>
                    <hr />
                    <p class="mb-1"><i class="fas fa-calendar me-2"></i>@eventItem.EventDate.ToString("MMM dd, yyyy")</p>
                    <p class="mb-0"><i class="fas fa-video me-2"></i>@eventItem.Sessions.Count Sessions</p>
                </div>
                <div class="card-footer bg-transparent">
                    <div class="btn-group w-100" role="group">
                        <a href="/Admin/EditEvent/@eventItem.EventId" class="btn btn-sm btn-warning">
                            <i class="fas fa-edit"></i> Edit
                        </a>
                        <form asp-action="ToggleEventStatus" asp-route-id="@eventItem.EventId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm @(eventItem.Status == "Active" ? "btn-secondary" : "btn-success")">
                                <i class="fas @(eventItem.Status == "Active" ? "fa-ban" : "fa-check")"></i>
                                @(eventItem.Status == "Active" ? "Deactivate" : "Activate")
                            </button>
                        </form>
                        <button onclick="deleteEvent('@eventItem.EventId')" class="btn btn-sm btn-danger">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </div>
                    <form id="deleteForm-@eventItem.EventId" asp-action="DeleteEvent" asp-route-id="@eventItem.EventId" method="post" style="display:none;"></form>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function deleteEvent(id) {
            if (confirm('Are you sure you want to delete this event? This will also delete all associated sessions.')) {
                document.getElementById('deleteForm-' + id).submit();
            }
        }
    </script>
}