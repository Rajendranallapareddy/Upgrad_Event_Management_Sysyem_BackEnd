@model IEnumerable<SpeakersDetails>
@{
    ViewData["Title"] = "Manage Speakers";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-users me-2"></i>Manage Speakers</h2>
    <a href="/Admin/CreateSpeaker" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Add Speaker
    </a>
</div>

<div class="row g-4">
    @foreach (var speaker in Model)
    {
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="fas fa-user-circle fa-4x text-primary mb-3"></i>
                    <h5 class="card-title">@speaker.SpeakerName</h5>
                    <p class="text-muted">@speaker.Sessions.Count Sessions</p>
                </div>
                <div class="card-footer bg-transparent text-center">
                    <form asp-action="DeleteSpeaker" asp-route-id="@speaker.SpeakerId" method="post" onsubmit="return confirm('Delete this speaker?')">
                        <button type="submit" class="btn btn-danger btn-sm">
                            <i class="fas fa-trash me-1"></i> Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>