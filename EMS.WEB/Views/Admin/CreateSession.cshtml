@model SessionInfo
@{
    ViewData["Title"] = "Create Session";
    Layout = "_AdminLayout";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Create New Session</h4>
            </div>
            <div class="card-body">
                <form asp-action="CreateSession" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="EventId" class="form-label required-field">Select Event</label>
                        <select asp-for="EventId" class="form-select" required>
                            <option value="">-- Select an Event --</option>
                            @if (ViewBag.Events != null)
                            {
                                foreach (var ev in ViewBag.Events)
                                {
                                    <option value="@ev.EventId">@ev.EventName - @ev.EventCategory</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="EventId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SessionTitle" class="form-label required-field"></label>
                        <input asp-for="SessionTitle" class="form-control" required />
                        <span asp-validation-for="SessionTitle" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SpeakerId" class="form-label">Assign Speaker (Optional)</label>
                        <select asp-for="SpeakerId" class="form-select">
                            <option value="">-- None --</option>
                            @if (ViewBag.Speakers != null)
                            {
                                foreach (var speaker in ViewBag.Speakers)
                                {
                                    <option value="@speaker.SpeakerId">@speaker.SpeakerName</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="SpeakerId" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="SessionStart" class="form-label required-field"></label>
                            <input asp-for="SessionStart" class="form-control" type="datetime-local" required />
                            <span asp-validation-for="SessionStart" class="text-danger"></span>
                            <small class="text-muted">Select local time (will be converted to UTC)</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="SessionEnd" class="form-label required-field"></label>
                            <input asp-for="SessionEnd" class="form-control" type="datetime-local" required />
                            <span asp-validation-for="SessionEnd" class="text-danger"></span>
                            <small class="text-muted">Select local time (will be converted to UTC)</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SessionUrl" class="form-label">Session URL (Optional)</label>
                        <input asp-for="SessionUrl" class="form-control" placeholder="https://" />
                        <span asp-validation-for="SessionUrl" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a href="/Admin/Sessions" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-success">Create Session</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Set default datetime values
            const now = new Date();
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const day = String(now.getDate()).padStart(2, '0');
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');
            const defaultDateTime = `${year}-${month}-${day}T${hours}:${minutes}`;
            
            const startInput = document.getElementById('SessionStart');
            const endInput = document.getElementById('SessionEnd');
            
            if (startInput && !startInput.value) {
                startInput.value = defaultDateTime;
            }
            
            if (endInput && !endInput.value) {
                // Set end time to 1 hour later
                const endDate = new Date(now.getTime() + 60 * 60 * 1000);
                const endYear = endDate.getFullYear();
                const endMonth = String(endDate.getMonth() + 1).padStart(2, '0');
                const endDay = String(endDate.getDate()).padStart(2, '0');
                const endHours = String(endDate.getHours()).padStart(2, '0');
                const endMinutes = String(endDate.getMinutes()).padStart(2, '0');
                endInput.value = `${endYear}-${endMonth}-${endDay}T${endHours}:${endMinutes}`;
            }
        });
    </script>
}