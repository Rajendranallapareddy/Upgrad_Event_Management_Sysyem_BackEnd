@model IEnumerable<ParticipantEventDetails>
@{
    ViewData["Title"] = "My Registered Events";
    Layout = "_Layout";
}

<div class="mb-4">
    <h2><i class="fas fa-calendar-check me-2"></i>My Registered Events</h2>
    <p class="text-muted">View and manage your event registrations</p>
</div>

<div class="row g-4">
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="alert alert-info text-center">
                <i class="fas fa-info-circle me-2"></i>You haven't registered for any events yet.
                <a href="/" class="alert-link">Browse events</a>
            </div>
        </div>
    }
    else
    {
        @foreach (var registration in Model)
        {
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h5 class="card-title text-primary">@registration.Event.EventName</h5>
                                <p class="text-muted small mb-2">@registration.Event.EventCategory</p>
                            </div>
                            <span class="badge @(registration.IsAttended ? "bg-success" : "bg-warning")">
                                @(registration.IsAttended ? "Attended" : "Upcoming")
                            </span>
                        </div>
                        
                        <div class="mt-3">
                            <p class="mb-1">
                                <i class="fas fa-calendar me-2 text-primary"></i>
                                @registration.Event.EventDate.ToString("MMMM dd, yyyy")
                            </p>
                            <p class="mb-1">
                                <i class="fas fa-clock me-2 text-primary"></i>
                                @registration.Event.Sessions.Count Sessions
                            </p>
                        </div>

                        @if (registration.Event.Sessions.Any())
                        {
                            <div class="mt-3">
                                <h6 class="small text-muted">Upcoming Sessions:</h6>
                                @foreach (var session in registration.Event.Sessions.Take(2))
                                {
                                    <div class="border-start border-primary ps-2 mb-1">
                                        <small class="d-block">
                                            <i class="fas fa-chalkboard-user me-1"></i> @session.SessionTitle
                                        </small>
                                        <small class="text-muted">@session.SessionStart.ToString("MMM dd, hh:mm tt")</small>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-transparent">
                        <div class="btn-group w-100" role="group">
                            <a href="/Home/EventDetails/@registration.Event.EventId" class="btn btn-sm btn-primary">
                                <i class="fas fa-eye me-1"></i> View Details
                            </a>
                            <form asp-action="CancelRegistration" asp-route-registrationId="@registration.Id" method="post" 
                                  onsubmit="return confirm('Are you sure you want to cancel your registration?')">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-times me-1"></i> Cancel
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>