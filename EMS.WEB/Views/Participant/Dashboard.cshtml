@model IEnumerable<ParticipantEventDetails>
@{
    ViewData["Title"] = "My Dashboard";
    Layout = "_Layout";
}

<div class="mb-4">
    <h2><i class="fas fa-tachometer-alt me-2"></i>My Dashboard</h2>
    <p class="text-muted">Welcome back, @User.Identity.Name!</p>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white shadow">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0">Registered Events</h6>
                        <h2 class="mb-0">@Model.Count()</h2>
                    </div>
                    <i class="fas fa-calendar-check fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<h4 class="mb-3">My Registered Events</h4>
<div class="row g-4">
    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="alert alert-info text-center">
                <i class="fas fa-info-circle me-2"></i>You haven't registered for any events yet.
                <a href="/" class="alert-link">Browse events</a>
            </div>
        </div>
    }
    else
    {
        @foreach (var registration in Model)
        {
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title text-primary">@registration.Event.EventName</h5>
                            <span class="badge @(registration.IsAttended ? "bg-success" : "bg-warning")">
                                @(registration.IsAttended ? "Attended" : "Upcoming")
                            </span>
                        </div>
                        <p class="text-muted small">@registration.Event.EventCategory</p>
                        <p class="mb-1"><i class="fas fa-calendar me-2"></i>@registration.Event.EventDate.ToString("MMMM dd, yyyy")</p>
                        <p class="mb-0"><i class="fas fa-clock me-2"></i>@registration.Event.Sessions.Count Sessions</p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="/Home/EventDetails/@registration.Event.EventId" class="btn btn-sm btn-primary">
                            <i class="fas fa-eye me-1"></i> View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>