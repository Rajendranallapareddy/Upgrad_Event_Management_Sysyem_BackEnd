@model IEnumerable<EventDetails>
@{
    ViewData["Title"] = $"{ViewBag.Category} Events";
    Layout = "_Layout";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active">@ViewBag.Category</li>
        </ol>
    </nav>
    <h2 class="text-primary">@ViewBag.Category Events</h2>
</div>

<div class="row g-4">
    @if (!Model.Any())
    {
        <div class="col-12 text-center">
            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>No events found in this category.
                <a href="/" class="alert-link">View all events</a>
            </div>
        </div>
    }
    else
    {
        @foreach (var eventItem in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card event-card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-primary">@eventItem.EventCategory</span>
                            <span class="badge bg-success">@eventItem.Status</span>
                        </div>
                        <h5 class="card-title">@eventItem.EventName</h5>
                        <p class="text-muted small">@eventItem.Description?.Substring(0, Math.Min(100, eventItem.Description?.Length ?? 0))...</p>
                        <div class="mt-3">
                            <p class="mb-1">
                                <i class="fas fa-calendar-alt me-2 text-primary"></i>
                                @eventItem.EventDate.ToString("MMMM dd, yyyy")
                            </p>
                            <p class="mb-1">
                                <i class="fas fa-clock me-2 text-primary"></i>
                                @eventItem.Sessions.Count Sessions
                            </p>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="/Home/EventDetails/@eventItem.EventId" class="btn btn-primary w-100">
                            <i class="fas fa-eye me-2"></i>View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>