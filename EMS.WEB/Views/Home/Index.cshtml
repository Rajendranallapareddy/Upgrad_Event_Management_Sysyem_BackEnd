@model IEnumerable<EventDetails>
@{
    ViewData["Title"] = "Home - Upcoming Events";
    Layout = "_Layout";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold text-primary">Welcome to upGrad Virtual Events</h1>
    <p class="lead">Discover and register for upcoming tech and industrial events</p>
</div>

@if (ViewBag.Categories != null && ((List<string>)ViewBag.Categories).Any())
{
    <div class="mb-4">
        <h5 class="mb-3">Browse by Category:</h5>
        <div class="d-flex flex-wrap gap-2">
            <a href="/" class="btn btn-outline-primary">All Events</a>
            @foreach (var category in ViewBag.Categories)
            {
                <a href="/Home/EventsByCategory?category=@category" class="btn btn-outline-secondary">@category</a>
            }
        </div>
    </div>
}

<div class="row g-4 mt-2">
    @if (!Model.Any())
    {
        <div class="col-12 text-center">
            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>No upcoming events available at the moment.
            </div>
        </div>
    }
    else
    {
        @foreach (var eventItem in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card event-card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-primary">@eventItem.EventCategory</span>
                            <span class="badge bg-success">@eventItem.Status</span>
                        </div>
                        <h5 class="card-title">@eventItem.EventName</h5>
                        <p class="text-muted small">@eventItem.Description?.Substring(0, Math.Min(100, eventItem.Description?.Length ?? 0))...</p>
                        <div class="mt-3">
                            <p class="mb-1">
                                <i class="fas fa-calendar-alt me-2 text-primary"></i>
                                @eventItem.EventDate.ToString("MMMM dd, yyyy")
                            </p>
                            <p class="mb-1">
                                <i class="fas fa-clock me-2 text-primary"></i>
                                @eventItem.Sessions.Count Sessions
                            </p>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="/Home/EventDetails/@eventItem.EventId" class="btn btn-primary w-100">
                            <i class="fas fa-eye me-2"></i>View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>